<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_cartoon_item"
    android:layout_marginBottom="8dp"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!-- App icon with subtle container -->
    <FrameLayout
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:background="@drawable/bg_icon_container"
        android:padding="3dp">

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="App Icon" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvUsageOrLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#98989D"
            android:fontFamily="sans-serif"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/cbSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="#FFFFFF"
        android:visibility="gone" />

    <EditText
        android:id="@+id/etLimit"
        android:layout_width="56dp"
        android:layout_height="36dp"
        android:hint="—"
        android:textColorHint="#48484A"
        android:textColor="#FFFFFF"
        android:inputType="number"
        android:background="@drawable/bg_input_field"
        android:visibility="gone"
        android:fontFamily="sans-serif-medium"
        android:textAlignment="center"
        android:textSize="14sp"
        android:padding="0dp"
        android:gravity="center" />

</LinearLayout>
